rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // helpers
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }
    
    function incoming() {
      return request.resource.data;
    }
    
    function existing() {
      return resource.data;
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Votes collection
    match /votes/{voteId} {
      allow read: if true; // Everyone can see the collective results/votes for stats
      
      allow create: if isSignedIn() 
                    && voteId == request.auth.uid
                    && isValidVote(incoming())
                    && incoming().userId == request.auth.uid
                    && incoming().createdAt == request.time;
                    
      allow update: if isOwner(voteId)
                    && isValidVote(incoming())
                    && incoming().userId == existing().userId
                    && incoming().createdAt == existing().createdAt
                    && incoming().diff(existing()).affectedKeys().hasOnly(['lineup', 'coachId', 'voterName']);
                    
      allow delete: if isOwner(voteId);
    }

    function isValidVote(data) {
      return data.keys().hasAll(['lineup', 'coachId', 'userId', 'createdAt'])
             && data.lineup is map
             // Simple size check for lineup - we expect 11 slots
             && data.lineup.keys().size() == 11
             && data.coachId is string
             && data.coachId.size() <= 50
             && data.userId is string
             && (data.get('voterName', '') is string && data.get('voterName', '').size() <= 100);
    }
  }
}
